rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'favorites', 'recents'])
        && data.keys().size() <= 5
        && data.email is string
        && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && data.favorites is list
        && data.favorites.size() <= 200
        && data.recents is list
        && data.recents.size() <= 50;
    }

    // Users Collection Rules (Strict ABAC)
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming()) 
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt // Immortal field check
        && (incoming().diff(existing()).affectedKeys().hasOnly(['favorites', 'recents', 'displayName']));
        
      allow delete: if false; // Disallowed to prevent user data purging via client
    }
  }
}
